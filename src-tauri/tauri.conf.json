{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Orca Coder",
  "version": "0.1.0",
  "identifier": "com.agentcanvas.app",
  "build": {
    "frontendDist": "../packages/client/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:client"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Orca Coder",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      },
      {
        "label": "tray-panel",
        "title": "Orca",
        "url": "tray.html",
        "width": 420,
        "height": 560,
        "minWidth": 360,
        "minHeight": 420,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": true,
        "visible": false,
        "center": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'; connect-src *"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Orchestrated canvas IDE for AI-assisted development",
    "longDescription": "Orca Coder — a multi-agent infinite canvas IDE for AI-assisted development"
  },
  "plugins": {}
}
