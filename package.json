{
  "name": "agent-canvas",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\" \"npm run dev:telemetry:node\"",
    "dev:client": "npm run dev --workspace=packages/client",
    "dev:server": "cargo run -p agent-canvas-server",
    "dev:telemetry:node": "PORT=3002 npm run dev --workspace=packages/server",
    "dev:server:node": "npm run dev --workspace=packages/server",
    "build": "npm run build --workspace=packages/client && cargo build -p agent-canvas-server --release",
    "build:daemon": "npm run build --workspace=packages/harness-headless && cargo build -p orca-daemon -p orca-cli --release",
    "build:client": "npm run build --workspace=packages/client",
    "build:server": "cargo build -p agent-canvas-server --release",
    "build:server:node": "npm run build --workspace=packages/server",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "type-check": "npm run type-check --workspace=packages/client && npm run type-check --workspace=packages/server",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md}\"",
    "rust:fmt": "cargo fmt",
    "rust:fmt:check": "cargo fmt -- --check",
    "rust:clippy": "cargo clippy --workspace -- -D warnings",
    "test:openrouter-vision": "node scripts/test-openrouter-vision-models.mjs --provider openrouter",
    "test:vision-badges": "node scripts/test-openrouter-vision-models.mjs",
    "test:models:smoke": "node scripts/smoke-models.mjs",
    "test:client-orchestrator": "npm run test --workspace=packages/client",
    "harness:eval": "npm run harness:eval --workspace=@agent-canvas/client",
    "vault:rebuild-markdown": "node scripts/rebuild-vault-markdown.mjs",
    "skills:sync": "node scripts/sync-skill-copies.mjs",
    "skills:check": "node scripts/sync-skill-copies.mjs --check",
    "test:hermes-tile": "node scripts/test-hermes-tile.mjs",
    "bridge:smoke": "bash scripts/bridge-smoke.sh",
    "doctor": "node scripts/orca-doctor.mjs",
    "orca:bridge": "node scripts/orca-bridge.mjs",
    "hermes:install-skills": "node scripts/install-hermes-skills.mjs",
    "telemetry:baseline-check": "node scripts/telemetry-baseline-check.mjs",
    "radar:scan": "npm run dev --workspace=packages/github-radar --",
    "radar:test": "npm run test --workspace=packages/github-radar",
    "radar:build": "npm run build --workspace=packages/github-radar"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tauri-apps/cli": "^2.5.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "typescript": "^5.4.5"
  }
}
