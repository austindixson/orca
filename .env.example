# Orca Coder Environment Configuration
# Copy this file to .env and fill in the required values

# =====================================================
# LLM Provider API Keys
# Priority: Settings UI > Tauri shell/env > Environment vars
# See packages/client/src/lib/llmCredentials.ts for details
# =====================================================

# OpenAI API Key (https://platform.openai.com/api-keys)
OPENAI_API_KEY=sk-...

# OpenAI Codex (specialized endpoint)
OPENAI_CODEX_BASE_URL=https://api.openai.com/v1

# Anthropic API Key (https://console.anthropic.com/settings/keys)
# Can also use OAuth token via desktop app (Pi Mono integration)
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_BASE_URL=https://api.anthropic.com

# Google Gemini API Key (https://ai.google.dev/)
GEMINI_API_KEY=...
GOOGLE_GENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter API Key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Z.AI (GLM) API Key (https://open.bigmodel.cn/)
ZAI_API_KEY=...
ZAI_CODING_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# Ollama (local)
OLLAMA_HOST=http://localhost:11434

# llama.cpp (local)
LLAMACPP_HOST=http://localhost:8080

# Mistral API Key (https://console.mistral.ai/)
MISTRAL_API_KEY=...
MISTRAL_BASE_URL=https://api.mistral.ai/v1

# Azure OpenAI
AZURE_OPENAI_API_KEY=...
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# GitHub Copilot (https://github.com/settings/copilot)
COPILOT_GITHUB_TOKEN=ghp_...

# Google Vertex AI
GOOGLE_CLOUD_ACCESS_TOKEN=...
GOOGLE_VERTEX_BASE_URL=https://generativelanguage.googleapis.com/v1beta
VERTEX_AI_BASE_URL=https://us-central1-aiplatform.googleapis.com

# AWS Bedrock
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Hermes (local orchestrator agent)
HERMES_API_BASE_URL=http://127.0.0.1:8642/v1
API_SERVER_KEY=...

# =====================================================
# Server Configuration
# =====================================================

# Server port (default: 3001)
PORT=3001

# Telemetry server port (default: 3002)
TELEMETRY_PORT=3002

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# =====================================================
# Application Configuration
# =====================================================

# Node environment
NODE_ENV=development

# Vite configuration
VITE_BASE_URL=/

# =====================================================
# Optional: Context7 MCP for documentation
# =====================================================

# Get free key at https://context7.com/dashboard
CONTEXT7_API_KEY=

# =====================================================
# Optional: Feature Flags
# =====================================================

# Enable Hermes gateway debug mode
HERMES_DEBUG=false

# Enable verbose logging
DEBUG=false

# =====================================================
# Notes
# =====================================================
#
# 1. Most API keys are optional - the app works with any subset of providers
# 2. Keys in Settings UI (desktop app) override environment variables
# 3. Hermes keys are read from ~/.hermes/.env by default (desktop app)
# 4. For local development, you typically only need the providers you use
# 5. See docs/SETUP.md for complete setup instructions
#
